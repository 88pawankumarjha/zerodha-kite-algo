# Zerodha Kite Connect credentials. Do not commit a real .env file.
KITE_API_KEY=
KITE_API_SECRET=

# Optional redirect URL used in your Kite developer app.
KITE_REDIRECT_URL=

# Safety defaults. Live orders require both of these to be set exactly.
DRY_RUN=true
LIVE_TRADING_ENABLED=false
CONFIRM_LIVE_ORDER=

# Default order settings. Keep these conservative and override per run.
DEFAULT_EXCHANGE=NFO
DEFAULT_PRODUCT=MIS
DEFAULT_VARIETY=regular
DEFAULT_VALIDITY=DAY
DEFAULT_TAG=algo-dryrun
