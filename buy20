#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 3 ] || [ "$#" -gt 4 ]; then
  echo "Usage: ./buy20 SYMBOL QTY BUY_PRICE [MIS|NRML]" >&2
  echo "Example: ./buy20 SENSEX2651475400CE 20 15" >&2
  echo "After MIS cutoff: ./buy20 SENSEX2651475400CE 20 15 NRML" >&2
  exit 2
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

if [ -x ".venv/bin/python" ]; then
  PYTHON=".venv/bin/python"
else
  PYTHON="python3"
fi

exec "$PYTHON" -m src.buy_option_with_sl \
  --exchange BFO \
  --symbol "$1" \
  --qty "$2" \
  --buy "$3" \
  ${4:+--product "$4"} \
  --stop-loss-percent 20
